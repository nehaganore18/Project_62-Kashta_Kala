<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_image_scrim.xml
     A dark gradient that sits at the BOTTOM of project images.
     Makes white badge text readable over any photo colour.
     Used as: android:background="@drawable/bg_image_scrim"
     Always place in a FrameLayout layered ON TOP of the ImageView.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#CC000000"
        android:endColor="#00000000" />
</shape>
