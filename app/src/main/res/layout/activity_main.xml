<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Home screen layout for Kashta-Kala app.
    Uses ScrollView → ConstraintLayout so cards look great on all screen sizes.
    Each feature is wrapped in a MaterialCardView (part of Material Design Components).
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F2"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        tools:context=".MainActivity">

        <!-- ── HEADER SECTION ──────────────────────────────────────────── -->

        <!-- Warm amber gradient banner -->

        <!-- App logo / icon placeholder -->

        <!-- App name -->

        <View
            android:id="@+id/headerBanner"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            android:longClickable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tagline -->

        <!-- Section label -->

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.04"
            android:text="Kashta-Kala"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/tvTagline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/headerBanner"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.06"
            android:text="Craftsmanship at Your Fingertips"
            android:textColor="#FFEDD5"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@+id/headerBanner"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAppName" />

        <TextView
            android:id="@+id/tvSectionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:text="EXPLORE"
            android:textColor="#92400E"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerBanner" />

        <!-- ── CARD 1 – FURNITURE CATALOG ─────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFurnitureCatalog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:rippleColor="#FBBF24"
            app:strokeColor="#FDE68A"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toStartOf="@id/cardMaterialCalculator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSectionLabel">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Icon circle -->
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_circle_amber">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="Furniture"
                        android:src="@drawable/ic_chair"
                        app:tint="#92400E" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Furniture\nCatalog"
                    android:textColor="#1C1917"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Browse all designs"
                    android:textColor="#78716C"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD 2 – MATERIAL CALCULATOR ──────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMaterialCalculator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:rippleColor="#6EE7B7"
            app:strokeColor="#D1FAE5"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardFurnitureCatalog"
            app:layout_constraintTop_toBottomOf="@id/tvSectionLabel">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_circle_green">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="Calculator"
                        android:src="@drawable/ic_calculate"
                        app:tint="#065F46" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Material\nCalculator"
                    android:textColor="#1C1917"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Estimate quantities"
                    android:textColor="#78716C"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD 3 – COST ESTIMATOR ────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCostEstimator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:rippleColor="#C4B5FD"
            app:strokeColor="#EDE9FE"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toStartOf="@id/cardPortfolio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFurnitureCatalog">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_circle_purple">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="Cost"
                        android:src="@drawable/ic_payments"
                        app:tint="#4C1D95" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Cost\nEstimator"
                    android:textColor="#1C1917"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Budget your project"
                    android:textColor="#78716C"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CARD 4 – PORTFOLIO ─────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPortfolio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:rippleColor="#FCA5A5"
            app:strokeColor="#FEE2E2"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardCostEstimator"
            app:layout_constraintTop_toBottomOf="@id/cardMaterialCalculator">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_circle_red">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="Portfolio"
                        android:src="@drawable/ic_photo_library"
                        app:tint="#7F1D1D" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Portfolio"
                    android:textColor="#1C1917"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Showcase your work"
                    android:textColor="#78716C"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── BOTTOM QUOTE STRIP ─────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FEF3C7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardCostEstimator">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_format_quote"
                    android:contentDescription="Quote"
                    app:tint="#D97706" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Wood is the only material that gives warmth to a home."
                    android:textColor="#92400E"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
