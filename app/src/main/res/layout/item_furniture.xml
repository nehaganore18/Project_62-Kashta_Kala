<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════╗
║  item_furniture.xml  —  SINGLE CARD LAYOUT                       ║
╚══════════════════════════════════════════════════════════════════╝

WHAT IS THIS FILE?
  This XML describes how ONE furniture card looks.
  RecyclerView will "recycle" (reuse) this template for every
  item in your list — so define it once, use it for all items!

VISUAL STRUCTURE OF ONE CARD:
  ┌─────────────────────────────────┐
  │  [  Furniture Image (160dp)  ]  │
  ├─────────────────────────────────┤
  │  🏷 CATEGORY badge              │
  │  Furniture Name (bold)          │
  │  ₹ Price          [→ Arrow]     │
  └─────────────────────────────────┘
-->

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFurniture"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:rippleColor="#FBBF24"
    app:strokeColor="#F5F0E8"
    app:strokeWidth="1dp">

    <!-- Root container: stacks image on top, text below -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── FURNITURE IMAGE ──────────────────────────────────────────
             scaleType="centerCrop" fills the box and crops edges neatly,
             just like cover-photo behaviour.
             Replace src with your own drawable images.              -->
        <ImageView
            android:id="@+id/ivFurnitureImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:contentDescription="Furniture image"
            android:src="@drawable/img_sofa"
            android:background="#FEF3C7" />

        <!-- ── TEXT SECTION ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp">

            <!-- CATEGORY BADGE (small pill label) -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seating"
                android:textColor="#92400E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_category_badge" />

            <!-- FURNITURE NAME -->
            <TextView
                android:id="@+id/tvFurnitureName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Teak Wood Sofa"
                android:textColor="#1C1917"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- PRICE ROW: price on left, arrow on right -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- PRICE TEXT -->
                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="₹28,000"
                    android:textColor="#D97706"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- VIEW DETAILS ARROW BUTTON -->
                <ImageView
                    android:id="@+id/ivArrow"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:background="@drawable/bg_arrow_circle"
                    android:padding="6dp"
                    android:contentDescription="View details"
                    app:tint="#92400E" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
